{
  "name": "spice_caption",
  "_note": "Speaker Q&A SF caption look (The reference editor house style, per the official Visual Guide). = caption-clips spice_1080 with: y=48% center (under chin), default weight = Medium / highlights = Black, guest=#FECB00 / speaker=#FFFFFF, numbers auto-Black. Color+italic per-word is set by qa_build's EDL director (guest => yellow+italic, speaker => white upright). fonts_dir resolves against the caption-clips skill (where generate_spice.py lives).",
  "video": { "width": 1080, "height": 1920 },
  "fonts_dir": "fonts/free_font",
  "weights": {
    "mute":     "Montserrat Light",
    "base":     "Montserrat Regular",
    "soft":     "Montserrat Medium",
    "strong":   "Montserrat Bold",
    "emphasis": "Montserrat Extrabold",
    "payoff":   "Montserrat Black"
  },
  "default_weight": "soft",
  "font_size_px": 80,
  "sizes": { "base": 100, "emph": 125, "strong": 150, "peak": 185 },
  "auto_size": { "numbers": "emph" },
  "italic_fax": -0.12,
  "colors": { "speaker": "FFFFFF", "guest": "FECB00" },
  "default_voice": "speaker",
  "number_color": null,
  "layout": {
    "y_percent_from_top": 48,
    "max_chars_per_line": 18,
    "max_words_per_screen": 3
  },
  "shadow": { "enabled": true, "alpha": 0, "offset_y": 8, "blur": 9, "color": "000000", "stroke_px": 7, "stroke_color": "000000" },
  "animation": {
    "position_drop_px": 8,
    "position_drop_duration_ms": 500,
    "opacity_from": 0.90,
    "opacity_fade_duration_ms": 83
  },
  "timing": { "onset_correct": true, "min_cue_dur": 0.40 },
  "auto_emphasis": {
    "numbers": "payoff",
    "words_strong": ["never","always","every","only","most","best","worst","nothing","everything","exactly","real","truth","proof","key","secret"]
  }
}
