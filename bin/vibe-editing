#!/usr/bin/env bash
# vibe-editing "<youtube-url-or-file>"  ->  finished vertical clips in a folder.
# Thin wrapper around Claude Code running the /edit workflow autonomously.
if [ -z "${1:-}" ]; then
  echo "usage: vibe-editing \"<youtube-url-or-file>\""; exit 1
fi
if ! command -v claude >/dev/null 2>&1; then
  echo "Claude Code CLI not found. Install it, then run:  /edit $*"; exit 1
fi
exec claude "Use the vibe-editing /edit workflow to turn this into finished, captioned, \
audited vertical clips fully autonomously, then tell me where they were delivered: $*"
